<!DOCTYPE html>
<html lang="en">

<head>
    <%- include ("../partials/header-scripts.ejs") %>
</head>

<body class="custom-cursor">

    <div class="custom-cursor__cursor"></div>
    <div class="custom-cursor__cursor-two"></div>


    <div class="preloader">
        <div class="preloader__image" style="background-image: url(/assets/images/nepali-roots/logos/logo-red.png);">
        </div>
    </div>

    <!-- /.preloader -->
    <div class="page-wrapper">

        <%- include ("../partials/header-menus.ejs") %>


            <section class="page-header @@extraClassName">
                <div class="page-header__bg"
                    style="background-image: url('/assets/images/nepali-roots/banners/subpage-banner-2.png');"></div>
                <!-- /.page-header__bg -->
                <div class="container">
                    <h2 class="page-header__title">Women of Nepali Roots</h2>
                    <ul class="cleenhearts-breadcrumb list-unstyled">
                        <li><i class="icon-home"></i> <a href="/">Home</a></li>
                        <li>
                            <a href="https://www.nepaliroots.org" target="_blank">

                                <span class="">Visit our website</span>
                            </a>

                        </li>
                    </ul><!-- /.thm-breadcrumb list-unstyled -->
                </div><!-- /.container -->
            </section><!-- /.page-header -->


            <section class="testimonials-two section-space">
                <div class="container">
                    <div class="testimonials-two__top">
                        <div class="row gutter-y-30 align-items-top">

                            <div class="col-lg-12">

                                <div class="event-details__time">
                                    <i class="event-details__time__icon fa fa-info-circle"></i>
                                    <span class="event-details__time__text">
                                        An Initiative by Nepali Roots e.V.
                                    </span>
                                </div>
                                <div class="volunteer-details__info">
                                    <div class="volunteer-details__info__top">
                                        <div class="volunteer-details__info__left">
                                            <h3 class="volunteer-details__name">Women of Nepali Roots</h3>
                                            <!-- /.volunteer-details__name -->
                                            <p class="volunteer-details__designation">
                                                Empowerment, solidarity, growth, and sustainable community building
                                            </p><!-- /.volunteer-details__designation -->
                                        </div><!-- /.volunteer-details__info__left -->

                                    </div><!-- /.volunteer-details__info__top -->
                                    <p class="volunteer-details__text">

                                        Women of Nepali Roots is a dedicated empowerment and networking initiative
                                        created to support women with Nepali migration backgrounds in Munich and beyond.
                                        As part of the broader mission of Nepali Roots e.V., the initiative focuses on
                                        strengthening educational growth, professional development, social integration,
                                        and community leadership among women.

                                    </p><!-- /.volunteer-details__text -->

                                    <div class="volunteer-details__info__top mt-4">
                                        <div class="volunteer-details__info__left">
                                            <h3 class="volunteer-details__name">Our Intent</h3>
                                        </div>
                                    </div>
                                    <p class="volunteer-details__text">
                                        Women of Nepali Roots was created in response to a growing need within the
                                        Nepali community for structured, women-centered support. Many women face unique
                                        challenges, including balancing family and career responsibilities, limited
                                        access to networks, social isolation, and psychosocial stress.
                                    </p>
                                    <p class="volunteer-details__text">
                                        Our intent is to provide a safe, inclusive, and culturally sensitive platform
                                        where women can:
                                    </p>
                                    <ul class="volunteer-details__text list-unstyled" style="padding-left: 20px;">
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Connect
                                            and build meaningful networks</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Share
                                            experiences and support one another</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Gain
                                            knowledge and practical tools for personal and professional growth</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Develop
                                            confidence and self-advocacy skills</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Engage
                                            in volunteerism and community leadership</li>
                                    </ul>
                                    <p class="volunteer-details__text">
                                        Through workshops, moderated Women Support Circles, and accessible online
                                        formats such as webinars and digital content, we aim to foster long-term
                                        empowerment, peer solidarity, and active civic participation.
                                    </p>

                                </div><!-- /.volunteer__info -->
                            </div>


                            <div class="col-lg-12">
                                <div class="volunteer-details__info">
                                    <div class="volunteer-details__info__top">
                                        <div class="volunteer-details__info__left">
                                            <h3 class="volunteer-details__name">
                                                Our Objectives
                                            </h3><!-- /.volunteer-details__name -->
                                        </div><!-- /.volunteer-details__info__left -->

                                    </div><!-- /.volunteer-details__info__top -->
                                    <p class="volunteer-details__text">
                                        Our core objectives are to:
                                    </p><!-- /.volunteer-details__text -->
                                    <ul class="volunteer-details__text list-unstyled" style="padding-left: 20px;">
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Empower
                                            women personally and professionally through targeted workshops and
                                            skill-building programs</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Improve
                                            access to information about education, career pathways, financial
                                            independence, and life in Germany</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Promote
                                            mental well-being by creating safe, supportive spaces for dialogue and peer
                                            exchange</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Strengthen
                                            leadership and communication skills to encourage active participation in
                                            society</li>
                                        <li><i class="fa fa-check-circle"
                                                style="color: var(--cleenhearts-base, #e5233d); margin-right: 10px;"></i>Build
                                            sustainable women-led structures within the Nepali community</li>
                                    </ul>

                                </div><!-- /.volunteer__info -->
                            </div>

                        </div><!-- /.row gutter-y-40 -->
                    </div><!-- /.testimonials-two__top -->

                </div>
            </section>

            <section class="event-details section-space-1">

                <div class="container">
                    <div class="row gutter-y-60">
                        <div class="col-lg-8">
                            <div class="event-details__content">

                                <h3 class="event-details__title">
                                    Our Long-Term Vision
                                </h3><!-- /.event-details__title -->
                                <div class="event-details__text">
                                    <p class="event-details__text__inner">
                                        We envision a strong, self-organized network of women who uplift one another and
                                        actively contribute to both the Nepali community and broader society in Germany.
                                        By strengthening women, we strengthen families, communities, and social cohesion
                                        at the local level.
                                    </p>
                                    <p class="event-details__text__inner">
                                        <b>Women of Nepali Roots stands for empowerment, solidarity, growth, and
                                            sustainable community building.</b>
                                    </p>

                                </div><!-- /.event-details__text -->

                            </div><!-- /.event-details__content -->

                            <div class="event-details__contact contact-information">
                                <a href="https://www.nepaliroots.org" target="_blank"
                                    class="contact-information__btn cleenhearts-btn">
                                    <div class="cleenhearts-btn__icon-box">
                                        <div class="cleenhearts-btn__icon-box__inner"><span
                                                class="icon-duble-arrow"></span></div>
                                    </div>
                                    <span class="cleenhearts-btn__text">Visit our website</span>
                                </a><!-- /.contact-information__btn -->
                                <div class="contact-information__phone">
                                    <div class="contact-information__phone__icon">
                                        <span class="icon-phone"></span>
                                    </div><!-- /.contact-information__phone__icon -->
                                    <div class="contact-information__phone__text">
                                        <span>Any questions?</span>
                                        <h5><a href="mailto:contact@nepaliroots.org">contact@nepaliroots.org</a></h5>
                                    </div><!-- /.contact-information__phone__text -->
                                </div><!-- /.event-details__contact contact-information__phone -->
                            </div><!-- /.contact-information -->

                        </div><!-- /.col-lg-8 -->
                        <div class="col-lg-4">
                            <aside class="sidebar-event">
                                <div class="sidebar-event__contact contact-one sidebar-event__item wow fadeInUp animated"
                                    data-wow-duration="1500ms" data-wow-delay="00ms"
                                    style="visibility: visible; animation-duration: 1500ms; animation-delay: 0ms; animation-name: fadeInUp;">
                                    <div class="contact-one__info">
                                        <div class="contact-one__info__item">
                                            <div class="contact-one__info__icon">
                                                <span class="icon-location"></span>
                                            </div><!-- /.contact-one__info__icon -->
                                            <div class="contact-one__info__content">
                                                <h4 class="contact-one__info__title">Location</h4>
                                                <address class="contact-one__info__text">Munich and beyond.</address>
                                            </div><!-- /.contact-one__info__content -->
                                        </div><!-- /.contact-one__info__item -->
                                        <div class="contact-one__info__item">
                                            <div class="contact-one__info__icon">
                                                <span class="icon-phone"></span>
                                            </div><!-- /.contact-one__info__icon -->
                                            <div class="contact-one__info__content">
                                                <h4 class="contact-one__info__title">Contact Info</h4>
                                                <a href="tel:+4915904739644"
                                                    class="contact-one__info__text contact-one__info__text--link">
                                                    +49 1590 4739644
                                                </a>
                                            </div><!-- /.contact-one__info__content -->
                                        </div><!-- /.contact-one__info__item -->
                                        <div class="contact-one__info__item">
                                            <div class="contact-one__info__icon">
                                                <span class="icon-envelope"></span>
                                            </div><!-- /.contact-one__info__icon -->
                                            <div class="contact-one__info__content">
                                                <h4 class="contact-one__info__title">Support email</h4>
                                                <a href="mailto:contact@nepaliroots.org"
                                                    class="contact-one__info__text contact-one__info__text--link">contact@nepaliroots.org
                                                    | nepaliroots@gmail.com</a>
                                            </div><!-- /.contact-one__info__content -->
                                        </div><!-- /.contact-one__info__item -->
                                    </div><!-- /.contact-one__info -->

                                    <div class="about-one__wrapper">
                                        <!-- /.row -->
                                        <div class="contact-information">
                                            <a href="https://www.nepaliroots.org" target="_blank"
                                                class="contact-information__btn cleenhearts-btn">
                                                <div class="cleenhearts-btn__icon-box">
                                                    <div class="cleenhearts-btn__icon-box__inner"><span
                                                            class="icon-duble-arrow"></span></div>
                                                </div>
                                                <span class="cleenhearts-btn__text">Visit our website</span>
                                            </a><!-- /.contact-information__btn -->

                                        </div>
                                    </div>


                                </div><!-- /.sidebar-event__contact -->

                            </aside><!-- /.sidebar-event -->
                        </div><!-- /.col-lg-4 -->

                    </div><!-- /.row -->
                </div><!-- /.container -->
            </section>




            <%- include ("../partials/footer.ejs") %>

    </div><!-- /.page-wrapper -->

    <%- include ("../partials/mobile-menus.ejs") %>


        <%- include ("../partials/scroll-to-top.ejs") %>
            <%- include ("../partials/sidebar-right-overlay.ejs") %>

                <%- include ("../partials/footer-scripts.ejs") %>
</body>

</html>